{
  "expo": {
    "name": "SAMER",
    "slug": "samtrackly",
    "version": "2.30",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "samtrackly",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.samer.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#EF9F27"
      },
      "package": "com.samer.app",
      "versionCode": 10,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {},
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#EF9F27"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Samtrackly a besoin d'accéder à votre galerie pour les photos.",
          "cameraPermission": "Samtrackly a besoin d'accéder à votre caméra pour les photos."
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1f840fa7-6f32-4302-a82f-4d8f258e96f6"
      }
    }
  }
}
